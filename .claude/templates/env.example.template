# =============================================================================
# .env.example — Modelo universal de variáveis de ambiente
# Copiar como .env.example, ajustar para sua stack.
# NUNCA colocar valores reais aqui — só placeholders.
# Adicionar .env ao .gitignore. Adicionar .env.example ao git.
# =============================================================================

# ----------------------------- AMBIENTE ---------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_NAME=meu-app
APP_URL=https://meusite.com.br
APP_KEY=SUA_CHAVE_AQUI_GERADA_COM_CSPRNG_32_BYTES

# ----------------------------- BANCO DE DADOS ---------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=NOME_DO_BANCO
DB_USERNAME=USUARIO_COM_PRIVILEGIO_MINIMO
DB_PASSWORD=SENHA_FORTE_AQUI

# Read replica (se aplicável)
# DB_READ_HOST=replica.example.com

# ----------------------------- CACHE / SESSÃO ---------------------------------
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Redis (se usar)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=SENHA_REDIS_AQUI

# ----------------------------- E-MAIL -----------------------------------------
MAIL_DRIVER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SUA_API_KEY_SENDGRID_AQUI
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@meusite.com.br
MAIL_FROM_NAME="Meu Site"

# ----------------------------- INTEGRAÇÕES EXTERNAS ---------------------------
# Pagamento (Stripe exemplo)
STRIPE_KEY=pk_test_SUA_CHAVE_PUBLICA
STRIPE_SECRET=sk_test_SUA_CHAVE_SECRETA
STRIPE_WEBHOOK_SECRET=whsec_SEU_WEBHOOK_SECRET

# IA (exemplo)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Maps / CEP
# GOOGLE_MAPS_API_KEY=AIza...
# VIACEP_BASE_URL=https://viacep.com.br/ws

# ----------------------------- CLOUD / STORAGE --------------------------------
# AWS S3 (exemplo)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=meu-bucket

# ----------------------------- ANALYTICS / TRACKING ---------------------------
# Apenas IDs públicos aqui
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
# GTM_ID=GTM-XXXXXXX
# META_PIXEL_ID=000000000000000

# ----------------------------- LOGGING / OBSERVABILIDADE ---------------------
LOG_CHANNEL=stack
LOG_LEVEL=info

# Sentry / Bugsnag (se usar)
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production

# ----------------------------- SEGURANÇA --------------------------------------
# CSP nonce (se usar nonce-based CSP)
# CSP_NONCE=GERADO_POR_REQUEST

# Rate limit
RATE_LIMIT_LOGIN_PER_HOUR=10
RATE_LIMIT_API_PER_MINUTE=60

# CSRF
CSRF_COOKIE_SECURE=true

# JWT (se usar)
# JWT_SECRET=GERAR_COM_CSPRNG_256_BITS
# JWT_TTL=15           # minutos para access token
# JWT_REFRESH_TTL=10080  # 7 dias para refresh token

# ----------------------------- FEATURE FLAGS ---------------------------------
FEATURE_NEW_CHECKOUT=false
FEATURE_AI_ASSISTANT=false

# Kill switch global do agente IA
AGENT_KILL_SWITCH=0

# ----------------------------- LGPD / PRIVACIDADE -----------------------------
# Contato do DPO/encarregado
DPO_EMAIL=dpo@meusite.com.br

# ----------------------------- DEPLOY -----------------------------------------
# Versão (idealmente injetado pelo CI)
# APP_VERSION=1.2.3
# DEPLOY_SHA=abc123def456

# =============================================================================
# REGRAS:
# 1. NUNCA colocar valor real aqui — sempre placeholder ou SUA_CHAVE_AQUI
# 2. .env (com valores reais) NUNCA vai pro Git
# 3. Em produção: usar secret manager (AWS Secrets, Vault, GitHub Secrets)
# 4. Rotacionar chaves periodicamente
# 5. Token diferente por ambiente (dev/staging/prod)
# 6. Quando mudar este arquivo, comunicar a equipe (variáveis novas)
# =============================================================================
