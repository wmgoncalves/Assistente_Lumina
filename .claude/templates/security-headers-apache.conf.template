#     "style-src 'self' 'nonce-{$nonce}' 'unsafe-inline'; " .
#     "img-src 'self' data: https:; " .
#     "font-src 'self' data:; " .
#     "frame-ancestors 'none'; " .
#     "form-action 'self'; " .
#     "base-uri 'self'");
#   define('CSP_NONCE', $nonce);
#   ?>
