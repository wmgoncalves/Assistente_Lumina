{
  "name": "lumina-scapini",
  "version": "2.0.0",
  "description": "Lúmina - Assistente de IA da Scapini Transportes",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch server.js --watch services/ --ignore app.js --ignore public/ server.js",
    "lumina": "node -e \"delete process.env.ELECTRON_RUN_AS_NODE;require('child_process').spawn(require('electron'),['.'],{stdio:'inherit',env:process.env}).on('exit',c=>process.exit(c))\"",
    "build-dataset": "node lumina-dataset-builder.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "composio": "^1.0.0",
    "composio-core": "^0.5.39",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "mammoth": "^1.12.0",
    "msedge-tts": "^2.0.5",
    "multer": "^2.1.1",
    "node-notifier": "^10.0.1",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^25.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "nodemon": "^3.1.14"
  }
}
