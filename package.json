{
  "name": "sky-scapini",
  "version": "2.0.0",
  "description": "Sky — Assistente de IA da Scapini Transportes",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "sky": "electron .",
    "build": "electron-builder --win --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "docx": "^9.7.1",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "msedge-tts": "^2.0.5",
    "multer": "^2.1.1",
    "node-notifier": "^10.0.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^25.1.0",
    "sky": "^0.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.scapini.sky",
    "productName": "Sky",
    "copyright": "Scapini Transportes",
    "win": {
      "target": "zip",
      "icon": "build/icon.ico",
      "artifactName": "Sky-${version}-${arch}.${ext}",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sky"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!**/*.md",
      "!config.json",
      "!memory.json",
      "!notes.json",
      "!embeddings.json",
      "!sky.db",
      "!habits.json",
      "!tasks.json",
      "!uploads/**",
      "!instalar.bat"
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "piper",
        "to": "piper",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "npmRebuild": true
  }
}
