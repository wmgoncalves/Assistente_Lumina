{
  "name": "lumina-scapini",
  "version": "2.0.0",
  "description": "Lúmina - Assistente de IA da Scapini Transportes",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch server.js --watch services/ --ignore app.js --ignore public/ server.js",
    "lumina": "node -e \"delete process.env.ELECTRON_RUN_AS_NODE;require('child_process').spawn(require('electron'),['.'],{stdio:'inherit',env:process.env}).on('exit',c=>process.exit(c))\""
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "docx": "^9.7.1",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "msedge-tts": "^2.0.5",
    "multer": "^2.1.1",
    "node-notifier": "^10.0.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^25.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "nodemon": "^3.1.14"
  }
}
